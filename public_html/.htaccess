<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /brokersconnect_dev/public_html/
    DirectoryIndex index.php

    # Pasar el header Authorization a PHP — Apache lo elimina por defecto en algunas configs
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # No reescribir si es un archivo o directorio real
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Redirigir todo lo demás a index.php — [QSA] preserva el query string explícitamente
    RewriteRule ^ index.php [L,QSA]
</IfModule>
