APP_NAME="Brokers Connector"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
DEBUGBAR_ENABLED=false
APP_URL=http://localhost
SESSION_DOMAIN=
ASSET_URL=http://localhost/

LOG_CHANNEL=stack

# 🗄️ PERSISTENCIA DE DATOS
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=brokersconnect_bd
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# 📩 NOTIFICACIONES (SENDGRID)
SENDGRID_API_KEY=

MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="BrokersConnector"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# 💳 PASARELA FINANCIERA (OPENPAY)
OPENPAY_ID=
OPENPAY_KEY_SECRET=
OPENPAY_KEY_PUBLIC=
OPENPAY_URL=https://api.openpay.mx/
OPENPAY_PRODUCTION=false

# Credenciales sandbox (paynet/spei — métodos legacy)
OPENPAY_SANDBOX_ID=
OPENPAY_SANDBOX_KEY=

# 🤖 INTELIGENCIA ARTIFICIAL (OPENAI)
OPENAI_API_KEY=
