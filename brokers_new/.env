MAIL_USERNAME=pagos@brokersconnector.com
MAIL_PASSWORD=Brokers01$$
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=pagos@brokersconnector.com
MAIL_FROM_NAME="BrokersConnector"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
