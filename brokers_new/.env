APP_NAME="Brokers Connector"
APP_ENV=production
APP_KEY=base64:$(php artisan key:generate --show)
APP_DEBUG=true
APP_URL=https://newbrokers.tourfindy.com/
ASSET_URL=https://newbrokers.tourfindy.com/

LOG_CHANNEL=stack

# 🗄️ PERSISTENCIA DE DATOS (BROKERSCONNECT_BD)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tourfindycom_newbrokers_db
DB_USERNAME=tourfindycom_newbrokers
DB_PASSWORD="0!DQq-a2go(zI39;"

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# 📩 NOTIFICACIONES (SENDGRID)
MAIL_DRIVER=smtp
